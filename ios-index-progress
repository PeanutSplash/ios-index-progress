#!/bin/bash
# 查看 iOS 设备 Spotlight 索引进度
# 用法: ios-index-progress [秒数]
#   默认监听 10 秒，传参可自定义时长
#   需要 iPhone 通过 USB 连接 Mac，且手机上打开「设置」App

set -euo pipefail

DURATION="${1:-10}"

if ! command -v brew &>/dev/null; then
  echo "❌ 未安装 Homebrew，请先访问 https://brew.sh 安装"
  exit 1
fi

if ! command -v idevicesyslog &>/dev/null; then
  echo "📦 正在安装 libimobiledevice..."
  brew install libimobiledevice
  echo ""
fi

if ! idevice_id -l 2>/dev/null | grep -q .; then
  echo "❌ 未检测到 iPhone，请确认："
  echo "   1. 已通过 USB 线连接 iPhone"
  echo "   2. 手机上已点击「信任此电脑」"
  exit 1
fi

echo "📱 监听 iPhone Spotlight 索引进度（${DURATION}秒）..."
echo "   💡 请确保手机上已打开「设置」App"
echo "   按 Ctrl+C 提前退出"
echo ""

LAST_PCT=""
idevicesyslog --match "PipelineCompleteness" 2>&1 | while IFS= read -r line; do
  pct=$(echo "$line" | grep -oE '[0-9]+%' || true)
  if [[ -n "$pct" && "$pct" != "$LAST_PCT" ]]; then
    LAST_PCT="$pct"
    echo "🔍 Spotlight 索引进度: $pct"
  fi
done &
PID=$!

sleep "$DURATION"
kill $PID 2>/dev/null
wait $PID 2>/dev/null

echo ""
echo "✅ 监听结束。如需继续查看，请重新运行本脚本。"
